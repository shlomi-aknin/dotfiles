[
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-h": "pane::ActivatePreviousItem",
      "cmd-l": "pane::ActivateNextItem",
      "cmd-[": "pane::SwapItemLeft",
      "cmd-]": "pane::SwapItemRight",
      // "space x": "workspace::CloseAllItemsAndPanes",
      "shift-h": ["workspace::SendKeystrokes", "^"],
      "shift-l": ["workspace::SendKeystrokes", "g _"],
      "s i '": ["workspace::SendKeystrokes", "v i ' p"],
      "s a '": ["workspace::SendKeystrokes", "v a ' p"],
      "s i \"": ["workspace::SendKeystrokes", "v i \" p"],
      "s a \"": ["workspace::SendKeystrokes", "v a \" p"],
      "s i {": ["workspace::SendKeystrokes", "v i { p"],
      "s a {": ["workspace::SendKeystrokes", "v a { p"],
      "s i }": ["workspace::SendKeystrokes", "v i } p"],
      "s a }": ["workspace::SendKeystrokes", "v a } p"],
      "s i [": ["workspace::SendKeystrokes", "v i [ p"],
      "s a [": ["workspace::SendKeystrokes", "v a [ p"],
      "s i ]": ["workspace::SendKeystrokes", "v i ] p"],
      "s a ]": ["workspace::SendKeystrokes", "v a ] p"],
      "s i (": ["workspace::SendKeystrokes", "v i ( p"],
      "s a (": ["workspace::SendKeystrokes", "v a ( p"],
      "s i )": ["workspace::SendKeystrokes", "v i ) p"],
      "s a )": ["workspace::SendKeystrokes", "v a ) p"],
      "s s": ["workspace::SendKeystrokes", "shift-v p"],
    },
  },
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      // "space s": "workspace::Save",
      "cmd-`": "terminal_panel::Toggle",
      // "space e": "workspace::ToggleLeftDock",
      // "space e": ["workspace::SendKeystrokes", "cmd-shift-e z z"],
      "cmd-shift-j": "workspace::ToggleBottomDock",
      // "space f": "file_finder::Toggle",
      "cmd-space": "command_palette::Toggle",
      // "cmd-shift-e": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "VimControl && vim_mode == normal",
    "bindings": {
      "space f": "file_finder::Toggle",
      "space e": ["workspace::SendKeystrokes", "cmd-shift-e z z"],
      "space s": "workspace::Save",
      "space q q": ["pane::CloseActiveItem", { "close_pinned": false }],
      "space x": "workspace::CloseAllItemsAndPanes",
      "space /": ["editor::ToggleComments", { "advance_downwards": false }],
      "space j": "editor::NewlineBelow",
      "space k": "editor::NewlineAbove",
    },
  },
  // {
  //   "context": "Pane",
  //   "use_key_equivalents": true,
  //   "bindings": {
  //     "space q q": ["pane::CloseActiveItem", { "close_pinned": false }],
  //   },
  // },
  {
    "context": "ProjectPanel",
    "use_key_equivalents": true,
    "bindings": {
      "shift-h": "project_panel::CollapseAllEntries",
      "l": "project_panel::Open",
      "cmd-l": ["workspace::SendKeystrokes", "space cmd-b"],
      "o": "project_panel::NewFile",
      "cmd-j": "project_panel::Duplicate",
      "O": "project_panel::NewDirectory",
      "x": "project_panel::Cut",
      "y": "project_panel::Copy",
      "p": "project_panel::Paste",
      "r": "project_panel::Rename",
      "d": ["project_panel::Trash", { "skip_prompt": true }],
      "escape": "menu::Cancel",
      "space e": ["workspace::SendKeystrokes", "cmd-b"],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "g p d": "editor::GoToDefinitionSplit",
      "g v": ["workspace::SendKeystrokes", "V g _ %"],
      // "space /": ["editor::ToggleComments", { "advance_downwards": false }],
    },
  },
  {
    "context": "VimControl && !menu || !Editor && !Terminal",
    "bindings": {
      "cmd-o": "pane::GoBack",
      "cmd-i": "pane::GoForward",
      "cmd-v": "vim::ToggleVisualBlock",
      "cmd-w": null,
      "cmd-w cmd-h": "workspace::ActivatePaneLeft",
      "cmd-w cmd-l": "workspace::ActivatePaneRight",
      "cmd-w cmd-k": "workspace::ActivatePaneUp",
      "cmd-w cmd-j": "workspace::ActivatePaneDown",
      "cmd-w h": "workspace::ActivatePaneLeft",
      "cmd-w l": "workspace::ActivatePaneRight",
      "cmd-w k": "workspace::ActivatePaneUp",
      "cmd-w j": "workspace::ActivatePaneDown",
      "cmd-w >": "vim::ResizePaneRight",
      "cmd-w <": "vim::ResizePaneLeft",
      "cmd-w -": "vim::ResizePaneDown",
      "cmd-w +": "vim::ResizePaneUp",
      "cmd-w _": "vim::MaximizePane",
      "cmd-w =": "vim::ResetPaneSizes",
      "cmd-w cmd-v": "pane::SplitVertical",
      "cmd-w v": "pane::SplitVertical",
      "cmd-w shift-s": "pane::SplitHorizontal",
      "cmd-w cmd-s": "pane::SplitHorizontal",
      "cmd-w s": "pane::SplitHorizontal",
      "cmd-w cmd-c": "pane::CloseActiveItem",
      "cmd-w c": "pane::CloseActiveItem",
      "cmd-w cmd-q": "pane::CloseActiveItem",
      "cmd-w q": "pane::CloseActiveItem",
    },
  },
  // {
  //   "context": "Editor && mode == full",
  //   "use_key_equivalents": true,
  //   "bindings": {
  //     "space j": "editor::NewlineBelow",
  //     "space k": "editor::NewlineAbove",
  //   },
  // },
  {
    "context": "Picker > Editor",
    "bindings": {
      "cmd-u": "editor::DeleteToBeginningOfLine",
      "cmd-k": "menu::SelectPrevious",
      "cmd-j": "menu::SelectNext",
      "cmd-l": ["workspace::SendKeystrokes", "enter"],
    },
  },
]
