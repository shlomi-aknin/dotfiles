// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "autosave": "on_focus_change",
  "vertical_scroll_margin": 30.0,
  "scroll_beyond_last_line": "off",
  "cursor_blink": false,
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": "Dracula Solid",
  "code_actions_on_format": {
    "source.organizeImports": true,
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "experimental.theme_overrides": {
    "element.hover": "#BD93F9",
    "ghost_element.selected": "#6272A4",
    "editor.background": "#000",
    "editor.active_line.background": "#44475A",
    "editor.debugger_active_line.background": "#6272A4",
    "editor.gutter.background": "#000",
    "editor.line_number": "#BD93F9",
    "search.match_background": "#6272A4",
    "hint": "#cccccc",
    "tab.active_background": "#6272A4",
    "players": [
      {
        "cursor": "#5ac1feff",
        "background": "#5ac1feff",
        "selection": "#BD93F9ff",
      },
    ],
    "syntax": {
      "comment": {
        "color": "#FF79C6",
      },
      "comment.doc": {
        "color": "#FF79C6",
      },
    },
  },
}
